    def cif(self):
        return self._cif

    @cif.setter
    def cif(self, value):
        if not isinstance(value, str) or len(value) != 9:
            raise ValueError("El CIF debe ser una cadena de 9 caracteres")
        self._cif = value

    @property
    def nombre(self):
        return self._nombre

    @nombre.setter
    def nombre(self, value):
        if not isinstance(value, str):
            raise ValueError("El nombre debe ser una cadena de texto")
        self._nombre = value


class Explotation:
    def __init__(self, cif=None, nombre=None):
        self.cif = cif
        self.nombre = nombre
        self.animales = []

    @property
    def cif(self):
        return self._cif

    @cif.setter
    def cif(self, value):
        if not isinstance(value, str) or len(value) != 9:
            raise ValueError("El CIF debe ser una cadena de 9 caracteres")
        self._cif = value

    @property
    def nombre(self):
        return self._nombre

    @nombre.setter
    def nombre(self, value):
        if not isinstance(value, str):
            raise ValueError("El nombre debe ser una cadena de texto")
        self._nombre = value

    def engadir_animal(self, n_animal):
        if n_animal in self.animales:
            return False
        else:
            self.animales.append(n_animal)
            return True

    def modificar_animal(self, animal_mod):
        for i, animal in enumerate(self.animales):
            if animal.cif == animal_mod.cif:
                self.animales[i] = animal_mod
                return True
        return False

    def mostrar_animais(self):
        return "\n".join([f"CIF: {animal.cif}, Nombre: {animal.nombre}" 
for animal in self.animales])


